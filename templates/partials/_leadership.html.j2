<div class="section" id="leadership">
  <div class="h2">Leadership &amp; culture</div>
  <div class="lede">{{ leadership.lede }}</div>
  <div class="cards">
    {% for p in leadership.pillars %}
    <div class="card">
      <h4>{{ p.title }}</h4>
      <p>{{ p.body }}</p>
      {% if p.tag %}<div class="mrow"><span class="k">Evidence</span><span class="v">{{ p.tag }}</span></div>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% if leadership.team_quotes %}
  <div class="teamquotes">
    <div class="dlabel">{{ leadership.team_quotes_label }}</div>
    <div class="quotes">
      {% for q in leadership.team_quotes %}
      <div class="quote"><div class="t">&ldquo;{{ q }}&rdquo;</div><div class="a">a direct report</div></div>
      {% endfor %}
    </div>
  </div>
  {% endif %}
  <p class="lede" style="margin-top:22px">{{ leadership.closing }}</p>
</div>
