<footer class="foot">
  <div class="wrap footgrid">
    <div class="footbrand">
      <div class="fname">{{ profile.name }}</div>
      {% if profile.location %}<div class="floc">{{ profile.location }}</div>{% endif %}
      <div class="ftag">{{ profile.positioning }}</div>
      <div class="fcopy">© 2026 {{ profile.name }}</div>
      <div class="fbuilt">Built on the Claude API</div>
    </div>
    <div class="footcol">
      <h5>Site</h5>
      {% for item in profile.nav %}<a href="{{ item.href }}"{% if item.chat %} data-chat-open{% endif %}>{{ item.label }}</a>{% endfor %}
    </div>
    <div class="footcol">
      <h5>Connect</h5>
      <div class="social">
      {% for l in profile.links %}
        <a href="{{ l.url }}" aria-label="{{ l.label }}"{% if l.type != 'email' %} target="_blank" rel="noopener"{% endif %}>{% if l.type == 'linkedin' %}<svg viewBox="0 0 24 24"><path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5zM0 8h5v16H0V8zm7.5 0h4.78v2.19h.07c.67-1.2 2.3-2.46 4.73-2.46C22.4 7.73 24 10.3 24 14.6V24h-5v-8.2c0-1.96-.04-4.48-2.73-4.48-2.73 0-3.15 2.13-3.15 4.34V24h-5V8z"/></svg>{% elif l.type == 'email' %}<svg viewBox="0 0 24 24"><path d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zm9 7L4 6.5V18h16V6.5z"/></svg>{% elif l.type == 'github' %}<svg viewBox="0 0 24 24"><path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.34-5.47-5.96 0-1.32.47-2.39 1.24-3.23-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.23 0 4.63-2.81 5.65-5.49 5.95.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/></svg>{% endif %}</a>
      {% endfor %}
      </div>
    </div>
  </div>
</footer>
